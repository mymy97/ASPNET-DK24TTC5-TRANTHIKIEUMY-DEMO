@{
    ViewBag.Title = "Sản phẩm theo loại";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

@model IEnumerable<ProTechTiveGear.Models.Item>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<style>
    .category-page {
        background-color: #fffaf5;
        padding: 80px 0;
        min-height: 80vh;
    }

    .premium-title-box {
        text-align: center;
        margin-bottom: 50px;
    }

    .premium-title {
        font-family: 'Playfair Display', serif;
        color: #4A2C2A;
        font-size: 38px;
        font-weight: 700;
        position: relative;
        display: inline-block;
        padding-bottom: 15px;
        text-transform: uppercase;
    }

    .premium-title:after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: #D2691E;
    }

    /* Card sản phẩm đồng bộ với Index */
    .product-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        transition: all 0.4s ease;
        border: 1px solid #f0f0f0;
        height: 100%;
        display: flex;
        flex-direction: column;
        margin-bottom: 30px;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(74, 44, 42, 0.1);
    }

    .product-img-wrapper {
        position: relative;
        padding-top: 100%; 
        overflow: hidden;
    }

    .product-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-info {
        padding: 20px;
        text-align: center;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .product-name {
        font-family: 'Poppins', sans-serif;
        font-size: 17px;
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
        text-decoration: none;
        display: block;
        min-height: 44px;
    }

    .product-price {
        font-size: 20px;
        color: #D2691E;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .btn-add-cart {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: #4A2C2A;
        color: #fff !important;
        padding: 10px 15px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
        font-size: 13px;
        transition: all 0.3s;
    }

    .btn-add-cart:hover {
        background: #D2691E;
    }

    .no-product {
        text-align: center;
        padding: 50px;
        font-style: italic;
        color: #999;
    }
</style>

<section class="category-page">
    <div class="container">
        <div class="premium-title-box">
            @{
                // Kiểm tra nếu Model có dữ liệu để lấy tên Loại/Thương hiệu
                var firstItem = Model.FirstOrDefault();
                var nameDisplay = firstItem != null ? firstItem.Brand.Name : "Danh mục sản phẩm";
            }
            <h2 class="premium-title">@nameDisplay</h2>
        </div>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 col-6">
                        <div class="product-card">
                            <div class="product-img-wrapper">
                                <a href="@Url.Action("Detail","AuraStore",new { id=item.ID})">
                                    <img class="product-img" src="~/img/Item/@item.Picture" alt="@item.Name">
                                </a>
                            </div>

                            <div class="product-info">
                                <a href="@Url.Action("Detail","AuraStore",new { id=item.ID})" class="product-name">@item.Name</a>
                                
                                <div class="product-price">
                                    @String.Format("{0:0,0}", item.SellPrice)đ
                                </div>

                                <div class="product-action">
                                    @if (item.Quantity == 0)
                                    {
                                        <button class="btn-add-cart" style="background: #ccc; cursor: not-allowed;" disabled>Hết hàng</button>
                                    }
                                    else
                                    {
                                        <a class="btn-add-cart" href="@Url.Action("AddtoCart","Cart",new {@id=item.ID,@strURL=Request.Url.ToString() })">
                                            <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 no-product">
                    <h3>Hiện chưa có sản phẩm nào thuộc mục này.</h3>
                    <a href="@Url.Action("Index", "AuraStore")" class="btn-add-cart" style="width: 200px; margin: 20px auto;">Quay lại cửa hàng</a>
                </div>
            }
        </div>
    </div>
</section>