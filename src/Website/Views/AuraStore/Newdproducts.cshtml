@model IEnumerable<ProTechTiveGear.Models.Item>

<style>
    /* Style riêng cho slider sản phẩm mới */
    .arivals_slider_wrapper {
        padding: 10px;
    }

    .premium_slider_item {
        background: #fff;
        border-radius: 15px;
        overflow: hidden;
        margin: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid #f0f0f0;
    }

    .premium_slider_item:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(74, 44, 42, 0.1);
    }

    /* Khung ảnh vuông đồng bộ */
    .slider_img_box {
        position: relative;
        padding-top: 100%;
        overflow: hidden;
    }

    .slider_img_box img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    /* Nội dung chữ */
    .slider_text_box {
        padding: 20px;
        text-align: center;
        background: #fff !important; /* Gỡ bỏ màu cam gạch cũ */
    }

    .slider_product_name {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 600;
        color: #4A2C2A;
        margin-bottom: 8px;
        display: block;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .slider_product_price {
        font-family: 'Poppins', sans-serif;
        font-size: 18px;
        color: #D2691E;
        font-weight: 700;
        margin-bottom: 15px;
        display: block;
    }

    /* Nút bấm nhỏ gọn cho slider */
    .btn_slider_cart {
        display: inline-block;
        background: #4A2C2A;
        color: #fff !important;
        padding: 8px 15px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s;
    }

    .btn_slider_cart:hover {
        background: #D2691E;
        box-shadow: 0 4px 10px rgba(210, 105, 30, 0.2);
    }
</style>

<div class="col-lg-6">
    <div class="arivals_slider owl-carousel arivals_slider_wrapper">
        @foreach (var item in Model)
        {
            <div class="item">
                <div class="premium_slider_item">
                    <a href="@Url.Action("Detail","AuraStore",new { id=item.ID})">
                        <div class="slider_img_box">
                            <img src="~/img/Item/@item.Picture" alt="@item.Name">
                        </div>
                    </a>
                    
                    <div class="slider_text_box">
                        <a href="@Url.Action("Detail","AuraStore",new { id=item.ID})" class="slider_product_name">
                            @item.Name
                        </a>
                        
                        <span class="slider_product_price">
                            @String.Format("{0:0,0}", item.SellPrice) đ
                        </span>
                        
                        @if (item.Quantity > 0)
                        {
                            <a class="btn_slider_cart" href="@Url.Action("AddtoCart","Cart",new {@id=item.ID,@strURL=Request.Url.ToString() })">
                                <i class="fas fa-shopping-cart"></i> Mua ngay
                            </a>
                        }
                        else
                        {
                            <span style="color: #ccc; font-size: 13px;">Hết hàng</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* Đảm bảo bạn đã khởi tạo Owl Carousel trong file Script chung của layout *@
<script>
    $(document).ready(function(){
        $(".arivals_slider").owlCarousel({
            items: 2,
            loop: true,
            margin: 10,
            autoplay: true,
            autoplayTimeout: 3000,
            nav: false,
            dots: true,
            responsive: {
                0: { items: 1 },
                768: { items: 2 }
            }
        });
    });
</script>