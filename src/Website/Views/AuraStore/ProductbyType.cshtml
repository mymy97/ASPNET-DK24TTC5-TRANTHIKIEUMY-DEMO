@{
    ViewBag.Title = "Sản phẩm theo loại";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

@model IEnumerable<ProTechTiveGear.Models.Item>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<style>
    .type-page {
        background-color: #fffaf5;
        padding: 80px 0;
        min-height: 80vh;
    }

    .premium-title-box {
        text-align: center;
        margin-bottom: 50px;
    }

    .premium-title {
        font-family: 'Playfair Display', serif;
        color: #4A2C2A;
        font-size: 38px;
        font-weight: 700;
        position: relative;
        display: inline-block;
        padding-bottom: 15px;
        text-transform: uppercase;
    }

    .premium-title:after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 80px;
        height: 3px;
        background: #D2691E;
    }

    .sub-title {
        color: #888;
        font-family: 'Poppins', sans-serif;
        margin-top: 10px;
    }

    /* Product Card Design */
    .product-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        transition: all 0.4s ease;
        border: 1px solid #f0f0f0;
        height: 100%;
        display: flex;
        flex-direction: column;
        margin-bottom: 30px;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(74, 44, 42, 0.15);
    }

    .product-img-wrapper {
        position: relative;
        padding-top: 100%; /* Giữ khung vuông */
        overflow: hidden;
    }

    .product-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .product-info {
        padding: 20px;
        text-align: center;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .product-name {
        font-family: 'Poppins', sans-serif;
        font-size: 17px;
        font-weight: 600;
        color: #333;
        margin-bottom: 12px;
        text-decoration: none;
        display: block;
        min-height: 44px;
    }

    .product-price {
        font-family: 'Poppins', sans-serif;
        font-size: 20px;
        color: #D2691E;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .btn-add-cart {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: #4A2C2A;
        color: #fff !important;
        padding: 10px 15px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
        transition: all 0.3s;
    }

    .btn-add-cart:hover {
        background: #D2691E;
        box-shadow: 0 5px 15px rgba(210, 105, 30, 0.3);
    }

    .empty-state {
        text-align: center;
        padding: 100px 0;
        color: #888;
    }
</style>

<section class="type-page">
    <div class="container">
        <div class="premium-title-box">
            @{
                // Kiểm tra an toàn để lấy tên Loại trà sữa
                var firstItem = Model.FirstOrDefault();
                var displayTitle = (firstItem != null && firstItem.ItemType != null) 
                                    ? firstItem.ItemType.TypeName 
                                    : "Danh Mục Sản Phẩm";
            }
            <h2 class="premium-title">@displayTitle</h2>
            <p class="sub-title">Khám phá hương vị trà sữa bạn yêu thích</p>
        </div>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 col-6">
                        <div class="product-card">
                            <div class="product-img-wrapper">
                                <a href="@Url.Action("Detail","AuraStore",new { id=item.ID})">
                                    <img class="product-img" src="~/img/Item/@item.Picture" alt="@item.Name">
                                </a>
                            </div>

                            <div class="product-info">
                                <a href="@Url.Action("Detail","AuraStore",new { id=item.ID})" class="product-name">@item.Name</a>
                                
                                <div class="product-price">
                                    @String.Format("{0:0,0}", item.SellPrice) <small>đ</small>
                                </div>

                                <div class="product-action">
                                    @if (item.Quantity > 0)
                                    {
                                        <a class="btn-add-cart" href="@Url.Action("AddtoCart","Cart",new {@id=item.ID,@strURL=Request.Url.ToString() })">
                                            <i class="fas fa-shopping-basket"></i> Thêm vào giỏ
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn-add-cart" style="background: #ccc; cursor: not-allowed;" disabled>Hết hàng</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 empty-state">
                    <i class="fas fa-mug-hot fa-3x mb-3" style="color: #eee;"></i>
                    <h3>Chưa có sản phẩm nào trong loại trà sữa này.</h3>
                    <br />
                    <a href="@Url.Action("Index", "AuraStore")" class="btn-add-cart" style="width: 200px; margin: 0 auto;">Quay lại thực đơn</a>
                </div>
            }
        </div>
    </div>
</section>